2026-07-13 23:52:46.058 [info] From claude: 2026-07-13T21:52:46.056Z [DEBUG] Hooks: Checking first line for async: {"session_id":"[REDACTED]","transcript_path":"C:\\Users\\z00571dh\\.claude\\projects\\c--Users-z00571dh-Documents-assignment\\1259c791-eb4e-46ae-b33e-663aba03788a.jsonl","cwd":"C:\\Users\\z00571dh\\Documents\\assignment","prompt_id":"69bcb792-de4b-42c5-a22c-4a66b397b5c2","permission_mode":"acceptEdits","effort":{"level":"medium"},"hook_event_name":"PreToolUse","tool_name":"Write","tool_input":{"file_path":"c:\\Users\\z00571dh\\Documents\\assignment\\eval\\harness.py","content":"\"\"\"\nEvaluation harness for the Legal Investigation Agent.\n\nUsage:\n    python eval/harness.py --scenario S1          # run one scenario\n    python eval/harness.py --all                  # run all scenarios\n    python eval/harness.py --all --output results/eval_results.json\n\nThe harness:\n  1. Sets up the document corpus for the scenario (copies only allowed documents to a temp dir)\n  2. Invokes the agent with the scenario goal\n  3. Scores the agent's final report against the hidden rubric\n  4. Prints a per-criterion breakdown and overall score\n  5. Writes results to JSON if --output is specified\n\"\"\"\n\nimport argparse\nimport json\nimport os\nimport shutil\nimport sys\nimport tempfile\nfrom pathlib import Path\nfrom datetime import datetime\n\n# Add project root to path so we can import agent and eval modules\nPROJECT_ROOT = Path(__file__).parent.parent\nsys.path.insert(0, str(PROJECT_ROOT))\n\nfrom eval.rubric import RUBRIC, MAX_SCORE, REQUIRED_CRITERIA\nfrom eval.scenarios import ALL_SCENARIOS, Scenario\n\nDOCUMENTS_DIR = PROJECT_ROOT / \"data\" / \"documents\"\nRESULTS_DIR = PROJECT_ROOT / \"results\"\n\n\n# ---------------------------------------------------------------------------\n# Corpus isolation\n# ---------------------------------------------------------------------------\n\ndef build_scenario_corpus(scenario: Scenario, tmp_dir: Path) -> Path:\n    \"\"\"Copy only the scenario's allowed documents into a temp directory.\"\"\"\n    corpus_dir = tmp_dir / \"corpus\"\n    corpus_dir.mkdir()\n    for filename in scenario.available_documents:\n        src = DOCUMENTS_DIR / filename\n        if not src.exists():\n            print(f\"  [WARN] Document not found in master corpus: {filename}\")\n            continue\n        shutil.copy(src, corpus_dir / filename)\n    return corpus_dir\n\n\n# ---------------------------------------------------------------------------\n# Agent invocation\n# ---------------------------------------------------------------------------\n\ndef run_agent(goal: str, corpus_dir: Path) -> str:\n    \"\"\"\n    Invoke the investigation agent and return its final report as a string.\n\n    This is the seam between the harness and the agent implementation.\n    Replace the import and call once the agent module exists.\n    \"\"\"\n    try:\n        from agent.runner import run_investigation\n        report = run_investigation(goal=goal, documents_dir=str(corpus_dir))\n        return report\n    except ImportError:\n        # Agent not yet implemented — return a stub so harness can be tested independently\n        print(\"  [INFO] Agent module not found. Running harness in stub mode.\")\n        return \"[STUB REPORT — agent not yet implemented]\"\n\n\n# ---------------------------------------------------------------------------\n# Scoring\n# ---------------------------------------------------------------------------\n\ndef score_report(report: str, scenario: Scenario) -> dict:\n    \"\"\"Score a report against the full rubric and return structured results.\"\"\"\n    results = []\n    total_score = 0.0\n\n    for criterion in RUBRIC:\n        score = criterion.check(report)\n        total_score += score\n\n        expected_gap = criterion.id in scenario.expected_gaps\n        expected_conflict = criterion.id in scenario.expected_conflicts\n\n        results.append({\n            \"id\": criterion.id,\n            \"category\": criterion.category,\n            \"description\": criterion.description,\n            \"required\": criterion.required,\n            \"score\": score,\n            \"grade\": _grade(score),\n            \"expected_gap\": expected_gap,\n            \"expected_conflict\": expected_conflict,\n            \"gap_correctly_flagged\": expected_gap and score >= 0.5,\n        })\n\n    required_passes = sum(\n        1 for r in results\n        if r[\"required\"] and r[\"score\"] >= 1.0\n    )\n    required_total = len(REQUIRED_CRITERIA)\n    scenario_pass = required_passes >= scenario.minimum_required_pass\n\n    return {\n        \"total_score\": round(total_score, 2),\n        \"max_score\": MAX_SCORE,\n        \"percentage\": round((total_score / MAX_SCORE) * 100, 1),\n        \"required_passes\": required_passes,\n        \"required_total\": required_total,\n        \"scenario_pass\": scenario_pass,\n        \"criteria\": results,\n    }\n\n\ndef _grade(score: float) -> str:\n    if score >= 1.0:\n        return \"PASS\"\n    if score >= 0.5:\n        return \"PARTIAL\"\n    return \"FAIL\"\n\n\n# ---------------------------------------------------------------------------\n# Reporting\n# ---------------------------------------------------------------------------\n\ndef print_scenario_result(scenario: Scenario, scoring: dict, report: str) -> None:\n    width = 72\n    print(\"\\n\" + \"=\" * width)\n    print(f\"  SCENARIO {scenario.id}: {scenario.name}\")\n    print(\"=\" * width)\n    print(f\"  Goal: {scenario.goal}\")\n    print(f\"  Documents: {len(scenario.available_documents)} available\")\n    print(f\"  {scenario.description}\")\n    print()\n\n    # Per-criterion table\n    print(f\"  {'ID':<14} {'Category':<28} {'Grade':<9} {'Score'}\")\n    print(f\"  {'-'*14} {'-'*28} {'-'*9} {'-'*5}\")\n    for c in scoring[\"criteria\"]:\n        flag = \" [REQUIRED]\" if c[\"required\"] else \"\"\n        gap_note = \" ← gap flagged\" if c[\"expected_gap\"] and c[\"gap_correctly_flagged\"] else \"\"\n        gap_warn = \" ← gap NOT flagged\" if c[\"expected_gap\"] and not c[\"gap_correctly_flagged\"] else \"\"\n        print(\n            f\"  {c['id']:<14} {c['category']:<28} {c['grade']:<9} {c['score']:.1f}\"\n            f\"{flag}{gap_note}{gap_warn}\"\n        )\n\n    print()\n    print(f\"  Total score:      {scoring['total_score']} / {scoring['max_score']} \"\n          f\"({scoring['percentage']}%)\")\n    print(f\"  Required passes:  {scoring['required_passes']} / {scoring['required_total']} \"\n          f\"(need {scenario.minimum_required_pass})\")\n    print(f\"  Scenario result:  {'PASS' if scoring['scenario_pass'] else 'FAIL'}\")\n    print(\"=\" * width)\n\n\ndef print_summary(all_results: list[dict]) -> None:\n    print(\"\\n\" + \"=\" * 72)\n    print(\"  EVALUATION SUMMARY\")\n    print(\"=\" * 72)\n    for r in all_results:\n        status = \"PASS\" if r[\"scoring\"][\"scenario_pass\"] else \"FAIL\"\n        print(\n            f\"  {r['scenario_id']:<6} {r['scenario_name']:<40} \"\n            f\"{r['scoring']['percentage']:>5.1f}%   {status}\"\n        )\n    passed = sum(1 for r in all_results if r[\"scoring\"][\"scenario_pass\"])\n    print(f\"\\n  {passed}/{len(all_results)} scenarios passed\")\n    print(\"=\" * 72 + \"\\n\")\n\n\n# ---------------------------------------------------------------------------\n# Main\n# ---------------------------------------------------------------------------\n\ndef run_scenario(scenario: Scenario, output_path: Path | None = None) -> dict:\n    print(f\"\\nRunning scenario {scenario.id}: {scenario.name}\")\n\n    with tempfile.TemporaryDirectory() as tmp:\n        tmp_dir = Path(tmp)\n        corpus_dir = build_scenario_corpus(scenario, tmp_dir)\n\n        print(f\"  Corpus: {len(list(corpus_dir.iterdir()))} documents loaded\")\n        print(\"  Invoking agent...\")\n\n        report = run_agent(goal=scenario.goal, corpus_dir=corpus_dir)\n        scoring = score_report(report, scenario)\n\n    print_scenario_result(scenario, scoring, report)\n\n    result = {\n        \"scenario_id\": scenario.id,\n        \"scenario_name\": scenario.name,\n        \"goal\": scenario.goal,\n        \"available_documents\": scenario.available_documents,\n        \"scoring\": scoring,\n        \"report_excerpt\": report[:500] + \"...\" if len(report) > 500 else report,\n        \"timestamp\": datetime.utcnow().isoformat(),\n    }\n    return result\n\n\ndef main() -> None:\n    parser = argparse.ArgumentParser(description=\"Legal Investigation Agent — Evaluation Harness\")\n    group = parser.add_mutually_exclusive_group(required=True)\n    group.add_argument(\"--scenario\", choices=[s.id for s in ALL_SCENARIOS],\n                       help=\"Run a single scenario by ID\")\n    group.add_argument(\"--all\", action=\"store_true\", help=\"Run all scenarios\")\n    parser.add_argument(\"--output\", type=str, help=\"Write results JSON to this path\")\n    args = parser.parse_args()\n\n    scenarios_to_run = ALL_SCENARIOS if args.all else [\n        s for s in ALL_SCENARIOS if s.id == args.scenario\n    ]\n\n    all_results = []\n    for scenario in scenarios_to_run:\n        result = run_scenario(scenario)\n        all_results.append(result)\n\n    if args.all:\n        print_summary(all_results)\n\n    if args.output:\n        out_path = Path(args.output)\n        out_path.parent.mkdir(parents=True, exist_ok=True)\n        with open(out_path, \"w\") as f:\n            json.dump(all_results, f, indent=2)\n        print(f\"Results written to {out_path}\")\n\n\nif __name__ == \"__main__\":\n    main()\n"},"tool_use_id":"toolu_vrtx_01Ff1kLqq3TtZGqgyZz4SxQ8"}

