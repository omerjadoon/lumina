e.current_step + i + 1}: {q}\\\"\\n        for i, q in enumerate(remaining)\\n    ) or \\\"  (none)\\\"\\n\\n    return (\\n        f\\\"GOAL: {state.goal}\\\\n\\\\n\\\"\\n        f\\\"NOTES SO FAR:\\\\n{notes_text}\\\\n\\\\n\\\"\\n        f\\\"REMAINING PLAN STEPS:\\\\n{remaining_text}\\\\n\\\\n\\\"\\n        f\\\"DOCUMENTS ALREADY READ: {', '.join(state.documents_read) or 'none'}\\\\n\\\"\\n        f\\\"ITERATION: {state.iterations}\\\"\\n    )\\n\\n\\n# ---------------------------------------------------------------------------\\n# plan\\n# ---------------------------------------------------------------------------\\n\\ndef plan(goal: str, docs: list[str]) -> list[str]:\\n    \\\"\\\"\\\"Return an ordered list of investigation questions (5–10 items).\\\"\\\"\\\"\\n    docs_list = \\\"\\\\n\\\".join(f\\\"  - {d}\\\" for d in docs)\\n    prompt = f\\\"\\\"\\\"\\\\\\nYou are a legal due diligence planner. Return a JSON object with a single key \\\"steps\\\" \\\\\\nwhose value is an ordered list of investigation questions (strings). Between 5 and 10 questions.\\n\\nGOAL: {goal}\\n\\nAVAILABLE DOCUMENTS:\\n{docs_list}\\n\\nRULES:\\n- Cover all five categories. Every category must have at least one step.\\n  Categories: IP Ownership | Contractual Obligations | Litigation & Liabilities | \\\\\\nCorporate Structure | Regulatory & Compliance\\n- Each question is specific and answerable from the documents above.\\n- Name the document you expect to consult in the question where possible.\\n- Look for conflicts between documents, not just confirmations. In particular:\\n  * If both an IP assignment and a university/research licence are present, one step must \\\\\\nask whether the licence's terms (non-transferability, derivative ownership) conflict with \\\\\\nthe assignment's representations.\\n  * If both a litigation register and an IP assignment are present, one step must ask \\\\\\nwhether any threatened IP claims conflict with the founder's sole-inventor representation.\\n- Flag gaps explicitly: if a document category appears absent, include a step to confirm that.\\n- Return JSON only. No commentary, no markdown fences.\\n\\nExample output shape:\\n{{\\\"steps\\\": [\\\"Question one?\\\", \\\"Question two?\\\", ...]}}\\n\\\"\\\"\\\"\\n    raw = _chat(\\n        messages=[{\\\"role\\\": \\\"user\\\", \\\"content\\\": prompt}],\\n        temperature=0,\\n        json_mode=True,\\n    )\\n    data = json.loads(raw)\\n    steps = data.get(\\\"steps\\\") or data.get(\\\"tasks\\\") or []\\n    if not isinstance(steps, list):\\n        raise ValueError(f\\\"plan() expected a list, got: {type(steps)}\\\")\\n    return [str(s) for s in steps]\\n\\n\\n# ---------------------------------------------------------------------------\\n# select_tool\\n# ---------------------------------------------------------------------------\\n\\ndef select_tool(state: InvestigationState, question: str) -> dict:\\n    \\\"\\\"\\\"Return {\\\"tool\\\": str, \\\"args\\\": dict} for the next tool call.\\\"\\\"\\\"\\n    summary = _state_summary(state)\\n    prompt = f\\\"\\\"\\\"\\\\\\nYou are a legal investigation executor. Choose exactly one tool to answer the current question.\\n\\nCURRENT QUESTION: {question}\\n\\nINVESTIGATION STATE:\\n{summary}\\n\\nAVAILABLE TOOLS:\\n  list_files(directory)            — lists all filenames in the corpus directory\\n  read_file(directory, filename)   — reads up to 8000 chars of a file\\n  search_in_file(directory, filename, query) — returns lines containing the query (case-insensitive)\\n\\nRULES:\\n- The corpus directory is always passed as the \\\"directory\\\" argument.\\n- Prefer search_in_file when looking for a specific clause, name, amount, or date.\\n- Use read_file when you need to understand the full structure of a short document.\\n- Use list_files only if you do not yet know which documents are available.\\n- Do not repeat a tool+filename+query combination already used in this investigation.\\n- Return JSON only. No commentary, no markdown fences.\\n\\nOutput shape:\\n{{\\\"tool\\\": \\\"<list_files|read_file|search_in_file>\\\", \\\"args\\\": {{<argument_name>: <value>}}}}\\n\\\"\\\"\\\"\\n    raw = _chat(\\n        messages=[{\\\"role\\\": \\\"user\\\", \\\"content\\\": prompt}],\\n        temperature=0,\\n        json_mode=True,\\n    )\\n    data = json.loads(raw)\\n    if \\\"tool\\\" not in data or \\\"args\\\" not in data:\\n        raise ValueError(f\\\"select_tool() missing keys in: {data}\\\")\\n    return data\\n\\n\\n# ---------------------------------------------------------------------------\\n# observe\\n# ---------------------------------------------------------------------------\\n\\ndef observe(state: InvestigationState, question: str, result: str) -> dict:\\n    \\\"\\\"\\\"Return {\\\"note\\\": Note, \\\"decision\\\": \\\"continue\\\"|\\\"replan\\\"|\\\"conclude\\\"}.\\\"\\\"\\\"\\n    summary = _state_summary(state)\\n    result_preview = result[:2000] if result else \\\"(empty — no content returned)\\\"\\n    prompt = f\\\"\\\"\\\"\\\\\\nYou are a legal investigation observer. Interpret the tool result and decide what to do next.\\n\\nCURRENT QUESTION: {question}\\n\\nTOOL RESULT:\\n{result_preview}\\n\\nINVESTIGATION STATE:\\n{summary}\\n\\nTASK:\\n1. Classify what the tool result tells you about the current question.\\n2. Choose a next action.\\n\\nNOTE KIND:\\n  finding  — the result answers the question with usable evidence\\n  gap      — the result is empty or the document is absent; the question cannot be answered\\n  conflict — the result reveals a contradiction with a prior finding or another document\\n\\nDECISION:\\n  continue — the question is answered (or confirmed unanswerable); move to the next step\\n  replan   — the result changes what needs to be investigated (missing doc, new conflict found, \\\\\\nor a better search is needed before concluding this step)\\n  conclude — all material questions are answered and the investigation is complete\\n\\nRULES:\\n- If the result is empty and no fallback search has been tried yet, choose replan.\\n- If the result is empty and a fallback was already attempted, choose continue (record a gap).\\n- If the result reveals a conflict between two documents, record it as a conflict note \\\\\\nand choose replan so the conflict can be investigated further if needed.\\n- Only choose conclude if the plan is substantially complete and all five categories have \\\\\\nat least one note.\\n- The category must be exactly one of: IP Ownership | Contractual Obligations | \\\\\\nLitigation & Liabilities | Corporate Structure | Regulatory & Compliance\\n- Return JSON only. No commentary, no markdown fences.\\n\\nOutput shape:\\n{{\\n  \\\"kind\\\": \\\"<finding|gap|conflict>\\\",\\n  \\\"category\\\": \\\"<category>\\\",\\n  \\\"description\\\": \\\"<one or two sentences summarising what was found, absent, or contradicted>\\\",\\n  \\\"sources\\\": [\\\"<filename>\\\", ...],\\n  \\\"decision\\\": \\\"<continue|replan|conclude>\\\"\\n}}\\n\\\"\\\"\\\"\\n    raw = _chat(\\n        messages=[{\\\"role\\\": \\\"user\\\", \\\"content\\\": prompt}],\\n        temperature=0.3,\\n        json_mode=True,\\n    )\\n    data = json.loads(raw)\\n\\n    kind = data.get(\\\"kind\\\", \\\"gap\\\")\\n    if kind not in (\\\"finding\\\", \\\"gap\\\", \\\"conflict\\\"):\\n        kind = \\\"gap\\\"\\n\\n    decision = data.get(\\\"decision\\\", \\\"continue\\\")\\n    if decision not in (\\\"continue\\\", \\\"replan\\\", \\\"conclude\\\"):\\n        decision = \\\"continue\\\"\\n\\n    note = Note(\\n        kind=kind,\\n        category=data.get(\\\"category\\\", \\\"IP Ownership\\\"),\\n        description=data.get(\\\"description\\\", \\\"\\\"),\\n        sources=data.get(\\\"sources\\\") or [],\\n    )\\n    return {\\\"note\\\": note, \\\"decision\\\": decision}\\n\\n\\n# ---------------------------------------------------------------------------\\n# replan\\n# ---------------------------------------------------------------------------\\n\\ndef replan(state: InvestigationState) -> list[str]:\\n    \\\"\\\"\\\"Return a revised list of remaining plan steps (does not include completed steps).\\\"\\\"\\\"\\n    summary = _state_summary(state)\\n    prompt = f\\\"\\\"\\\"\\\\\\nYou are a legal investigation replanner. The investigation has encountered a gap or conflict \\\\\\nand must adapt its remaining plan.\\n\\nINVESTIGATION STATE:\\n{summary}\\n\\nTASK:\\nReturn a revised list of remaining investigation steps as a JSON object with key \\\"steps\\\".\\n\\nRULES:\\n- Do not repeat steps that are already reflected in the notes.\\n- If a document was absent, add a fallback step to search other documents for related terms.\\n- If a conflict was found, add a step to gather more evidence about that conflict.\\n- Keep steps specific and concrete — name documents or search terms where known.\\n- Between 1 and 8 steps. These replace the remaining steps in the current plan.\\n- Cover any categories not yet represented in the notes.\\n- Return JSON only. No commentary, no markdown fences.\\n\\nOutput shape:\\n{{\\\"steps\\\": [\\\"Revised step one?\\\", \\\"Revised step two?\\\", ...]}}\\n\\\"\\\"\\\"\\n    raw = _chat(\\n        messages=[{\\\"role\\\": \\\"user\\\", \\\"content\\\": prompt}],\\n        temperature=0.3,\\n        json_mode=True,\\n    )\\n    data = json.loads(raw)\\n    steps = data.get(\\\"steps\\\") or []\\n    if not isinstance(steps, list):\\n        raise ValueError(f\\\"replan() expected a list, got: {type(steps)}\\\")\\n    return [str(s) for s in steps]\\n\\n\\n# ---------------------------------------------------------------------------\\n# conclude\\n# ---------------------------------------------------------------------------\\n\\ndef conclude(state: InvestigationState) -> str:\\n    \\\"\\\"\\\"Return the final prose report synthesised from state.notes only.\\\"\\\"\\\"\\n    notes_text = \\\"\\\\n\\\".join(\\n        f\\\"[{n.kind.upper()}] {n.category}\\\\n  {n.description}\\\\n  Sources: {', '.join(n.sources) or 'none'}\\\"\\n        for n in state.notes\\n    ) or \\\"(no notes recorded)\\\"\\n\\n    prompt = f\\\"\\\"\\\"\\\\\\nYou are a legal due diligence report writer. Produce a structured report addressed to an \\\\\\nacquirer evaluating whether to proceed with an acquisition.\\n\\nGOAL: {state.goal}\\n\\nINVESTIGATION NOTES:\\n{notes_text}\\n\\nINSTRUCTIONS:\\n- Base every claim on the notes above. Do not invent facts.\\n- Structure the report under exactly these five headings (include each even if only a gap):\\n  1. IP Ownership\\n  2. Contractual Obligations\\n  3. Litigation & Liabilities\\n  4. Corporate Structure\\n  5. Regulatory & Compliance\\n- Under each heading: state findings first, then gaps, then conflicts.\\n- For gaps: write \\\"No document confirming X was available.\\\"\\n- For conflicts: name both sources and explain the specific contradiction.\\n- After the five sections, add a CONCLUSION section (2–4 sentences) that directly answers \\\\\\nthe goal — state whether the investigation supports proceeding, proceeding with conditions, \\\\\\nor not proceeding, and name the specific blockers or risks.\\n- Plain English. No bullet points inside sections — prose only. Maximum 800 words.\\n- Cite source documents by filename in parentheses.\\n\\\"\\\"\\\"\\n    return _chat(\\n        messages=[{\\\"role\\\": \\\"user\\\", \\\"content\\\": prompt}],\\n        temperature=0,\\n        json_mode=False,\\n    )\\n\"},\"tool_use_id\":\"toolu_vrtx_014xpEYzFqZBbPCuFZ3u2xf6\"}\n"

