 select_tool\nmock_planner.observe = observe\nmock_planner.replan = replan\nmock_planner.conclude = conclude\n\nsys.modules['agent.planner'] = mock_planner\n\nfrom agent.runner import run_investigation\nreport = run_investigation('Can Orion Capital safely acquire Nexus Legal Technologies?', 'data/documents')\nprint()\nprint('=== REPORT ===')\nprint(report)\n\"\n","description":"Structural smoke test with mocked planner"},"updatedPermissions":[]}}}
